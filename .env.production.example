# Copy to .env on the server, fill in real values, never commit.
# Generate strong secrets, e.g.:
#   DB_PASSWORD=$(openssl rand -base64 24 | tr -d '/+=' | cut -c1-32)
#   JWT_SECRET=$(openssl rand -hex 48)

# --- Postgres ---
DB_USER=postgres
DB_PASSWORD=__CHANGE_ME__
DB_NAME=infrastructure_safety
DB_SSL=false
# Host port for Postgres (bound to 127.0.0.1 only by docker-compose.yml)
DB_HOST_PORT=5432

# --- API ---
# JWT signing key. MUST be long and random.
JWT_SECRET=__CHANGE_ME__
# Comma-separated origins allowed by CORS. Empty = allow all (fine when the SPA
# is served from the same nginx as the API). Example for a separate frontend:
# ALLOWED_ORIGINS=https://example.com,https://www.example.com
ALLOWED_ORIGINS=
# Trust X-Forwarded-* from the front nginx. "1" = trust one hop.
TRUST_PROXY=1
# Auto-load db.json on first start when the table is empty.
AUTO_SEED=true

# --- Web (nginx) ---
# Port published on the host. 80 if this server is the public edge.
WEB_PORT=80
