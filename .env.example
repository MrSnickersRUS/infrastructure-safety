# Copy this file to .env and fill in the values

# PostgreSQL connection (used by the API server)
# Option A — full connection string (takes priority)
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/infrastructure_safety

# Option B — individual fields (used when DATABASE_URL is not set)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=infrastructure_safety

# Set to "true" if your Postgres requires SSL (e.g. Supabase, Neon, etc.)
DB_SSL=false

# JWT secret — change to a long random string in production
JWT_SECRET=dev-secret

# API port (default 3001)
PORT=3001
